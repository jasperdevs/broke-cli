{
  "name": "@jasperdevs/brokecli",
  "version": "0.0.1",
  "description": "Terminal-first AI coding CLI with budget-aware model routing.",
  "type": "module",
  "exports": {
    ".": "./dist/sdk.mjs"
  },
  "main": "./dist/sdk.mjs",
  "module": "./dist/sdk.mjs",
  "bin": {
    "brokecli": "dist/brokecli.mjs"
  },
  "files": [
    "dist",
    "data",
    "logos"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "benchmark:tasks": "npm run build && node scripts/benchmark-harness.mjs",
    "test": "vitest run",
    "test:release": "node scripts/release-smoke.mjs",
    "test:efficiency": "vitest run test/efficiency-benchmarks.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && node scripts/quality-check.mjs",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "coding",
    "llm",
    "terminal",
    "cost",
    "budget",
    "anthropic",
    "openai",
    "ollama"
  ],
  "author": "jasperdevs",
  "license": "MIT",
  "homepage": "https://github.com/jasperdevs/broke-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasperdevs/broke-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jasperdevs/broke-cli/issues"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/mistral": "^3.0.28",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/xai": "^3.0.77",
    "ai": "^6.0.146",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "js-tiktoken": "^1.0.21",
    "jsonc-parser": "^3.3.1",
    "marked": "^15.0.12",
    "strip-ansi": "^7.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.15.2",
    "opentype.js": "^1.3.4",
    "sharp": "^0.34.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
